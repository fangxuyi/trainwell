# Neon PostgreSQL connection string
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Groq for Whisper transcription (free tier: ~8 hours audio/day)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Server-side language-model provider for workout extraction and Ask AI.
# Supported values: anthropic (default) or openai. "claude" is accepted as an
# alias for anthropic. These values and model names are never exposed to users.
AI_PROVIDER=anthropic

# Anthropic configuration
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI configuration (required only when AI_PROVIDER=openai)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6-terra

# Vercel Blob storage (auto-generated when you enable Blob in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Mobile app base URL (set on Vercel, referenced by mobile app)
NEXT_PUBLIC_API_URL=https://your-app.vercel.app

# Clerk auth — publishable key is public, secret key is server-only
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Temporary private-beta gate. Run the migration before setting this to true.
BETA_INVITE_REQUIRED=false

# Protects migration and invitation-code administration routes.
ADMIN_SECRET=replace-with-a-long-random-secret

# Stripe Checkout for web purchases
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CREDITS_100_PRICE_ID=price_xxx
STRIPE_MONTHLY_300_PRICE_ID=price_xxx
STRIPE_MONTHLY_800_PRICE_ID=price_xxx

# RevenueCat webhook for iOS App Store purchases
# Configure this exact value as the webhook Authorization header in RevenueCat.
REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer replace-with-a-long-random-secret
REVENUECAT_CREDITS_100_PRODUCT_ID=trainwell_credits_100
REVENUECAT_MONTHLY_300_PRODUCT_ID=trainwell_monthly_300
REVENUECAT_MONTHLY_800_PRODUCT_ID=trainwell_monthly_800

# Optional licensed exercise media host. Relative image/GIF paths from the
# exercise dataset are resolved against this HTTPS base URL. Do not configure
# the public reference repository unless you have separate media usage rights.
EXERCISE_MEDIA_BASE_URL=https://your-licensed-media-host.example/
