# Neon PostgreSQL connection string
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Groq for Whisper transcription (free tier: ~8 hours audio/day)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Anthropic for Claude extraction and Q&A
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Blob storage (auto-generated when you enable Blob in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Mobile app base URL (set on Vercel, referenced by mobile app)
NEXT_PUBLIC_API_URL=https://your-app.vercel.app

# Clerk auth — publishable key is public, secret key is server-only
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Stripe Checkout for web purchases
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CREDITS_100_PRICE_ID=price_xxx
STRIPE_MONTHLY_300_PRICE_ID=price_xxx
STRIPE_MONTHLY_800_PRICE_ID=price_xxx

# RevenueCat webhook for iOS App Store purchases
# Configure this exact value as the webhook Authorization header in RevenueCat.
REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer replace-with-a-long-random-secret
REVENUECAT_CREDITS_100_PRODUCT_ID=trainwell_credits_100
REVENUECAT_MONTHLY_300_PRODUCT_ID=trainwell_monthly_300
REVENUECAT_MONTHLY_800_PRODUCT_ID=trainwell_monthly_800
